//Rules to follow//
//Model names should be singular and start with an uppercase letter.
//Field names should be in camelCase.
//Use appropriate data types for each field.
//Define relationships between models using @relation attribute.
// & write in the first model the relation field as an array if one-to-many.

generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

//Models

model BusinessType {
  id       String  @id @default(cuid())
  value    String  @unique // retail, wholesale, pharmacy
  labelEn  String
  labelBn  String
  isActive Boolean @default(true)

  businesses Business[]

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  categories Category[]
}

model Business {
  id        String   @id @default(cuid())
  name      String
  nameBn    String?
  type      String   @default("retail")
  phone     String?
  email     String?
  address   String?
  logo      String?
  currency  String   @default("BDT")
  timezone  String   @default("Asia/Dhaka")
  language  String   @default("bn")
  plan      String   @default("free")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  accounts          Account[]
  auditLogs         AuditLog[]
  branches          Branch[]
  categories        Category[]
  expenses          Expense[]
  expenseCategories ExpenseCategory[]
  items             Item[]
  otps              Otp[]
  parties           Party[]
  partyCategories   PartyCategory[]
  partyLedger       PartyLedger[]
  payments          Payment[]
  quotations        Quotation[]
  sales             Sale[]
  stockLedger       StockLedger[]
  users             User[]
  businessType      BusinessType?     @relation(fields: [businessTypeId], references: [id])
  businessTypeId    String
  purchases         Purchase[]
  purchaseReturns   PurchaseReturn[]
  saleReturns       SaleReturn[]
  purchaseOrders    PurchaseOrder[]
  paymentPlans      PaymentPlan[]
}

enum AuthProvider {
  EMAIL
  GOOGLE
  GITHUB
  PHONE
}

model User {
  id              String       @id @default(cuid())
  businessId      String
  phone           String       @unique
  isPhoneVerified Boolean      @default(false)
  name            String?
  email           String?
  role            String       @default("owner") // owner, admin, staff
  branchId        String?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  auditLogs       AuditLog[]
  provider        AuthProvider @default(PHONE)
  expenses        Expense[]
  sales           Sale[]
  branch          Branch?      @relation(fields: [branchId], references: [id])
  business        Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([phone])
}

model Otp {
  id         String    @id @default(cuid())
  businessId String?
  phone      String    @unique
  code       String
  purpose    String    @default("login")
  attempts   Int       @default(0)
  verified   Boolean   @default(false)
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  business   Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([phone])
  @@index([expiresAt])
}

model Branch {
  id          String     @id @default(cuid())
  businessId  String
  name        String
  nameBn      String?
  type        String     @default("main")
  address     String?
  phone       String?
  managerId   String?
  isActive    Boolean    @default(true)
  isMain      Boolean    @default(false)
  openingCash Float      @default(0)
  currentCash Float      @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  accounts    Account[]
  business    Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  expenses    Expense[]
  items       Item[]
  parties     Party[]
  sales       Sale[]
  users       User[]
  purchases   Purchase[]

  @@index([businessId])
}

model Purchase {
  id              String    @id @default(cuid())
  businessId      String
  branchId        String?
  purchaseOrderId String?
  supplierId      String?
  invoiceNo       String?
  grnNo           String? // Goods Received Note
  subtotal        Float
  discount        Float     @default(0)
  tax             Float     @default(0)
  total           Float
  paidAmount      Float     @default(0)
  dueAmount       Float     @default(0)
  status          String    @default("received") // draft, received, cancelled, returned, partially_returned
  notes           String?
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  supplier Party?           @relation(fields: [supplierId], references: [id])
  branch   Branch?          @relation(fields: [branchId], references: [id])
  business Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items    PurchaseItem[]
  returns  PurchaseReturn[]

  @@index([businessId])
  @@index([businessId, branchId])
  @@index([businessId, branchId, createdAt])
  @@index([supplierId])
  @@index([createdAt])
  @@index([status])
  @@index([deletedAt])
}

model PurchaseItem {
  id          String    @id @default(cuid())
  purchaseId  String
  itemId      String
  batchId     String?
  itemName    String
  quantity    Float
  unitCost    Float
  total       Float
  returnedQty Float     @default(0)
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  item     Item     @relation(fields: [itemId], references: [id])
  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([purchaseId])
  @@index([itemId])
  @@index([deletedAt])
}

model PurchaseReturn {
  id           String    @id @default(cuid())
  businessId   String
  branchId     String?
  purchaseId   String
  returnNo     String // PRN-YYYYMMDD-XXXX
  supplierId   String?
  subtotal     Float
  discount     Float     @default(0)
  tax          Float     @default(0)
  total        Float
  refundAmount Float     @default(0)
  refundMethod String? // cash, debit_note, bank
  status       String    @default("completed") // draft, completed, cancelled
  reason       String?
  notes        String?
  createdBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  purchase Purchase             @relation(fields: [purchaseId], references: [id])
  business Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items    PurchaseReturnItem[]

  @@unique([businessId, returnNo])
  @@index([businessId])
  @@index([purchaseId])
  @@index([createdAt])
  @@index([deletedAt])
}

model PurchaseReturnItem {
  id               String    @id @default(cuid())
  purchaseReturnId String
  purchaseItemId   String
  itemId           String
  itemName         String
  quantity         Float
  unitCost         Float
  total            Float
  reason           String?
  createdAt        DateTime  @default(now())
  deletedAt        DateTime?

  purchaseReturn PurchaseReturn @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)

  @@index([purchaseReturnId])
  @@index([itemId])
  @@index([deletedAt])
}

model PartyCategory {
  id          String   @id @default(cuid())
  businessId  String
  name        String
  nameBn      String?
  description String?
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  parties     Party[]
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model Party {
  id              String    @id @default(cuid())
  businessId      String
  branchId        String?
  categoryId      String?
  name            String
  phone           String?
  email           String?
  address         String?
  type            String    @default("customer") // customer, supplier, both
  customerTier    String? // regular, wholesale, vip, premium
  openingBalance  Float     @default(0)
  currentBalance  Float     @default(0)
  creditLimit     Float?
  paymentTerms    Int? // Payment terms in days
  notes           String?
  isActive        Boolean   @default(true)
  riskLevel       String? // low, medium, high
  lastPaymentDate DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  category     PartyCategory? @relation(fields: [categoryId], references: [id])
  branch       Branch?        @relation(fields: [branchId], references: [id])
  business     Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  partyLedger  PartyLedger[]
  payments     Payment[]
  paymentPlans PaymentPlan[]
  purchases    Purchase[]
  sales        Sale[]

  @@index([businessId])
  @@index([branchId])
  @@index([type])
  @@index([deletedAt])
}

model PaymentPlan {
  id                String    @id @default(cuid())
  businessId        String
  partyId           String
  saleId            String?
  totalAmount       Float
  paidAmount        Float     @default(0)
  remainingAmount   Float
  totalInstallments Int       @default(1)
  frequency         String    @default("monthly") // weekly, biweekly, monthly
  startDate         DateTime
  endDate           DateTime?
  status            String    @default("active") // active, completed, cancelled, defaulted
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  business           Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  party              Party         @relation(fields: [partyId], references: [id])
  installmentRecords Installment[]

  @@index([businessId])
  @@index([partyId])
  @@index([status])
  @@index([deletedAt])
}

model Installment {
  id             String    @id @default(cuid())
  paymentPlanId  String
  installmentNo  Int
  amount         Float
  dueDate        DateTime
  paidDate       DateTime?
  paidAmount     Float     @default(0)
  status         String    @default("pending") // pending, paid, partial, overdue
  reminderSent   Boolean   @default(false)
  reminderSentAt DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  paymentPlan PaymentPlan @relation(fields: [paymentPlanId], references: [id], onDelete: Cascade)

  @@index([paymentPlanId])
  @@index([dueDate])
  @@index([status])
  @@index([deletedAt])
}

model PartyLedger {
  id            String   @id @default(cuid())
  businessId    String
  branchId      String?
  partyId       String
  type          String
  referenceId   String?
  referenceType String?
  amount        Float
  balance       Float
  description   String
  date          DateTime
  createdAt     DateTime @default(now())
  party         Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([partyId])
  @@index([date])
}

model Category {
  id             String   @id @default(cuid())
  businessTypeId String? // null = global (applies to all types)
  businessId     String? // null = template, set = custom business category
  name           String
  nameBn         String?
  description    String?
  parentId       String?
  itemCount      Int      @default(0)
  isTemplate     Boolean  @default(false) // true = seeded template
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  businessType BusinessType? @relation(fields: [businessTypeId], references: [id])
  business     Business?     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items        Item[]

  @@unique([businessTypeId, name]) // prevent duplicate template names per type
  @@unique([businessId, name]) // prevent duplicate names per business
  @@index([businessTypeId])
  @@index([businessId])
}

model Item {
  id               String         @id @default(cuid())
  businessId       String
  branchId         String?
  categoryId       String?
  name             String
  nameBn           String?
  sku              String?
  barcode          String?
  description      String?
  unit             String         @default("pcs")
  costPrice        Float          @default(0)
  sellingPrice     Float          @default(0)
  wholesalePrice   Float?
  vipPrice         Float?
  minimumPrice     Float?
  currentStock     Float          @default(0)
  minStock         Float          @default(0)
  maxStock         Float?
  supplierId       String?
  imageUrl         String?
  isActive         Boolean        @default(true)
  lastPurchaseDate DateTime?
  lastSaleDate     DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  category         Category?      @relation(fields: [categoryId], references: [id])
  branch           Branch?        @relation(fields: [branchId], references: [id])
  business         Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  saleItems        SaleItem[]
  stockLedger      StockLedger[]
  purchaseItems    PurchaseItem[]

  @@index([businessId])
  @@index([branchId])
  @@index([categoryId])
}

model StockLedger {
  id            String   @id @default(cuid())
  businessId    String
  branchId      String?
  itemId        String
  type          String
  quantity      Float
  previousStock Float
  newStock      Float
  fromBranchId  String?
  toBranchId    String?
  referenceId   String?
  referenceType String?
  reason        String?
  notes         String?
  createdBy     String?
  createdAt     DateTime @default(now())
  item          Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([itemId])
  @@index([createdAt])
}

model Sale {
  id            String       @id @default(cuid())
  businessId    String
  branchId      String?
  invoiceNo     String
  partyId       String?
  subtotal      Float
  discount      Float        @default(0)
  tax           Float        @default(0)
  total         Float
  paidAmount    Float        @default(0)
  dueAmount     Float        @default(0)
  paymentMethod String       @default("cash")
  pricingTier   String?
  status        String       @default("completed")
  profit        Float        @default(0)
  notes         String?
  createdBy     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  payments      Payment[]
  party         Party?       @relation(fields: [partyId], references: [id])
  branch        Branch?      @relation(fields: [branchId], references: [id])
  business      Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user          User?        @relation(fields: [createdBy], references: [id])
  items         SaleItem[]
  saleReturns   SaleReturn[]

  @@unique([businessId, invoiceNo])
  @@index([businessId])
  @@index([partyId])
  @@index([createdAt])
}

model SaleItem {
  id        String   @id @default(cuid())
  saleId    String
  itemId    String
  itemName  String
  quantity  Float
  unitPrice Float
  costPrice Float
  discount  Float    @default(0)
  total     Float
  profit    Float
  createdAt DateTime @default(now())
  item      Item     @relation(fields: [itemId], references: [id])
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([itemId])
}

model SaleReturn {
  id           String    @id @default(cuid())
  businessId   String
  branchId     String?
  saleId       String
  returnNo     String // SRN-YYYYMMDD-XXXX
  partyId      String?
  subtotal     Float
  discount     Float     @default(0)
  tax          Float     @default(0)
  total        Float
  refundAmount Float     @default(0)
  refundMethod String? // cash, credit_note, bank
  status       String    @default("completed") // draft, completed, cancelled
  reason       String?
  notes        String?
  createdBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  sale     Sale             @relation(fields: [saleId], references: [id])
  business Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items    SaleReturnItem[]

  @@unique([businessId, returnNo])
  @@index([businessId])
  @@index([saleId])
  @@index([createdAt])
  @@index([deletedAt])
}

model SaleReturnItem {
  id           String    @id @default(cuid())
  saleReturnId String
  saleItemId   String
  itemId       String
  itemName     String
  quantity     Float
  unitPrice    Float
  costPrice    Float
  discount     Float     @default(0)
  total        Float
  reason       String?
  createdAt    DateTime  @default(now())
  deletedAt    DateTime?

  saleReturn SaleReturn @relation(fields: [saleReturnId], references: [id], onDelete: Cascade)

  @@index([saleReturnId])
  @@index([itemId])
  @@index([deletedAt])
}

// ============================================
// PURCHASES & RETURNS
// ============================================

model PurchaseOrder {
  id           String    @id @default(cuid())
  businessId   String
  branchId     String?
  supplierId   String?
  poNo         String // PO-YYYYMMDD-XXXX
  subtotal     Float
  discount     Float     @default(0)
  tax          Float     @default(0)
  total        Float
  status       String    @default("draft") // draft, submitted, approved, partially_received, received, cancelled
  expectedDate DateTime?
  notes        String?
  createdBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  business Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  items    PurchaseOrderItem[]

  @@unique([businessId, poNo])
  @@index([businessId])
  @@index([createdAt])
  @@index([status])
  @@index([deletedAt])
}

model PurchaseOrderItem {
  id              String    @id @default(cuid())
  purchaseOrderId String
  itemId          String
  itemName        String
  quantity        Float
  unitCost        Float
  total           Float
  receivedQty     Float     @default(0)
  status          String    @default("pending") // pending, partially_received, received
  createdAt       DateTime  @default(now())
  deletedAt       DateTime?

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([itemId])
  @@index([deletedAt])
}

model Payment {
  id         String   @id @default(cuid())
  businessId String
  branchId   String?
  partyId    String
  type       String
  mode       String   @default("cash")
  accountId  String?
  amount     Float
  reference  String?
  saleId     String?
  purchaseId String?
  notes      String?
  createdBy  String?
  createdAt  DateTime @default(now())
  sale       Sale?    @relation(fields: [saleId], references: [id])
  party      Party    @relation(fields: [partyId], references: [id])
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([partyId])
  @@index([createdAt])
}

model ExpenseCategory {
  id         String    @id @default(cuid())
  businessId String?
  name       String
  nameBn     String?
  icon       String?
  color      String?
  isDefault  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  expenses   Expense[]
  business   Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, name])
  @@index([businessId, name])
}

model Expense {
  id          String          @id @default(cuid())
  businessId  String
  branchId    String?
  categoryId  String
  accountId   String?
  amount      Float
  description String
  date        DateTime
  receipt     String?
  createdBy   String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  category    ExpenseCategory @relation(fields: [categoryId], references: [id])
  branch      Branch?         @relation(fields: [branchId], references: [id])
  business    Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user        User?           @relation(fields: [createdBy], references: [id])

  @@index([businessId])
  @@index([categoryId])
  @@index([date])
}

model Account {
  id               String    @id @default(cuid())
  businessId       String
  branchId         String?
  name             String
  nameBn           String?
  type             String    @default("cash")
  accountNumber    String?
  bankName         String?
  mobileNumber     String?
  currentBalance   Float     @default(0)
  openingBalance   Float     @default(0)
  currency         String    @default("BDT")
  status           String    @default("active")
  isDefault        Boolean   @default(false)
  lastReconciledAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  branch           Branch?   @relation(fields: [branchId], references: [id])
  business         Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model Quotation {
  id                String   @id @default(cuid())
  businessId        String
  branchId          String?
  quotationNo       String
  partyId           String?
  partyName         String?
  items             String
  subtotal          Float
  discount          Float    @default(0)
  tax               Float    @default(0)
  total             Float
  validityDate      DateTime
  quotationDate     DateTime
  status            String   @default("draft")
  convertedToSaleId String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  business          Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, quotationNo])
  @@index([businessId])
  @@index([partyId])
  @@index([status])
}

model AuditLog {
  id         String   @id @default(cuid())
  businessId String
  branchId   String?
  userId     String?
  userName   String?
  action     String
  entity     String
  entityId   String?
  entityName String?
  oldValue   String?
  newValue   String?
  ipAddress  String?
  userAgent  String?
  notes      String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}
