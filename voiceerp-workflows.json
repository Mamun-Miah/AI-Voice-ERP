{
	"info": {
		"_postman_id": "voiceerp-workflows-id",
		"name": "VoiceERP Workflows",
		"description": "Automated workflows for VoiceERP. After each request, variables are saved to the environment automatically.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Signup Flow",
			"item": [
				{
					"name": "Step 1: Register Business",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Mamun Miah\",\n  \"phone\": \"+8801234567890\",\n  \"businessName\": \"Voice Tech ERP\",\n  \"businessType\": \"retail\",\n  \"password\": \"StrongPass@123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/register",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"auth",
								"register"
							]
						}
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const jsonData = pm.response.json();",
									"if (jsonData.success) {",
									"    pm.environment.set(\"userId\", jsonData.data.userId);",
									"    pm.environment.set(\"lastOtp\", jsonData.data.otp);",
									"    console.log(\"Saved userId and OTP to environment\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "Step 2: Verify OTP",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"uuid\": \"{{userId}}\",\n  \"code\": \"{{lastOtp}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/verify-otp",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"auth",
								"verify-otp"
							]
						}
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const jsonData = pm.response.json();",
									"if (jsonData.accessToken) {",
									"    pm.environment.set(\"accessToken\", jsonData.accessToken);",
									"    pm.environment.set(\"businessId\", jsonData.user.businessId);",
									"    console.log(\"Saved accessToken to environment\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					]
				}
			]
		},
		{
			"name": "2. Inventory Setup",
			"item": [
				{
					"name": "Create Main Cash Account",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Main Cash\",\n  \"type\": \"cash\",\n  \"openingBalance\": 10000,\n  \"isActive\": true\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/accounts",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"accounts"
							]
						}
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const jsonData = pm.response.json();",
									"if (jsonData.data) {",
									"    pm.environment.set(\"accountId\", jsonData.data.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "Create Supplier",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Unilever Dist.\",\n  \"phone\": \"+8801999999999\",\n  \"type\": \"supplier\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/parties",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"parties"
							]
						}
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const jsonData = pm.response.json();",
									"if (jsonData.data) {",
									"    pm.environment.set(\"supplierId\", jsonData.data.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "Create Product (Item)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Lux Soap\",\n  \"sku\": \"LUX-001\",\n  \"unit\": \"pcs\",\n  \"costPrice\": 45,\n  \"sellingPrice\": 55,\n  \"currentStock\": 0,\n  \"trackBatch\": true\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/items",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"items"
							]
						}
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const jsonData = pm.response.json();",
									"if (jsonData.data) {",
									"    pm.environment.set(\"itemId\", jsonData.data.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					]
				}
			]
		},
		{
			"name": "3. Purchase Workflow",
			"item": [
				{
					"name": "Stock In (Purchase)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{accessToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"supplierId\": \"{{supplierId}}\",\n  \"accountId\": \"{{accountId}}\",\n  \"items\": [\n    {\n      \"itemId\": \"{{itemId}}\",\n      \"quantity\": 100,\n      \"unitCost\": 45,\n      \"trackBatch\": true,\n      \"batchNumber\": \"B101\"\n    }\n  ],\n  \"paidAmount\": 4500,\n  \"status\": \"received\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/purchases",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"purchases"
							]
						}
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const jsonData = pm.response.json();",
									"if (jsonData.data) {",
									"    pm.environment.set(\"lastPurchaseId\", jsonData.data.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					]
				}
			]
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://127.0.0.1:8000/api",
			"type": "string"
		}
	]
}
